# Koofr Hermes — config template
# Copy to .env and fill in your credentials.

# REQUIRED: Generate an app password at https://app.koofr.net/app/admin/preferences/password
KOOFR_EMAIL=you@example.com
KOOFR_PASSWORD=your-app-password-here

# Optional:
# KOOFR_API_BASE=https://app.koofr.net
# KOOFR_PORT=5000
# KOOFR_HOST=127.0.0.1
# KOOFR_DB=$HOME/.koofr-hermes/cache.db
# KOOFR_REFRESH_INTERVAL=3600
